{
  "functions": {
    "source": "backend/cloud-functions"
  },
  "hosting": {
    "site": "smart-finance-ia",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".git/**",
      ".serena/**",
      ".firebase/**",
      "**/node_modules/**",
      "backend/**",
      "novas_demandas.md",
      "playstore_publicacao.md"
    ],
    "redirects": [
      {
        "source": "/admin",
        "destination": "/admin.html",
        "type": 302
      },
      {
        "source": "/termos",
        "destination": "/termos-de-uso.html",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
