rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNonNegativeNumber(value) {
      return value is number && value >= 0;
    }

    function hasValidTransactionShape(data) {
      return data.keys().hasOnly([
          'hash',
          'dedupKey',
          'date',
          'title',
          'value',
          'category',
          'accountType',
          'bankAccount',
          'active',
          'createdBy',
          'createdAt',
          'updatedAt',
          'categorySource',
          'categoryAutoAssigned',
          'categoryManuallyEdited',
          'lastCategoryUpdateAt',
          'transactionOrigin',
          'providerTransactionId',
          'providerItemId',
          'providerAccountId',
          'providerStatus',
          'deletedByProvider'
        ])
        && data.hash is string
        && (!('dedupKey' in data) || (data.dedupKey is string && data.dedupKey.size() > 0 && data.dedupKey.size() <= 320))
        && data.date is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.value is number
        && data.value >= 0
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 50
        && data.accountType in ['Crédito', 'Conta']
        && (!('createdBy' in data) || data.createdBy in ['import', 'manual'])
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50))
        && (!('categorySource' in data) || (data.categorySource is string && data.categorySource.size() > 0 && data.categorySource.size() <= 60))
        && (!('categoryAutoAssigned' in data) || data.categoryAutoAssigned is bool)
        && (!('categoryManuallyEdited' in data) || data.categoryManuallyEdited is bool)
        && (!('lastCategoryUpdateAt' in data) || (data.lastCategoryUpdateAt is string && data.lastCategoryUpdateAt.size() <= 50))
        && (!('transactionOrigin' in data) || data.transactionOrigin in ['import', 'manual', 'open-finance'])
        && (!('providerTransactionId' in data) || (data.providerTransactionId is string && data.providerTransactionId.size() <= 140))
        && (!('providerItemId' in data) || (data.providerItemId is string && data.providerItemId.size() <= 140))
        && (!('providerAccountId' in data) || (data.providerAccountId is string && data.providerAccountId.size() <= 140))
        && (!('providerStatus' in data) || (data.providerStatus is string && data.providerStatus.size() <= 40))
        && (!('deletedByProvider' in data) || data.deletedByProvider is bool)
        && (!('bankAccount' in data) || (
          data.bankAccount is string
          && data.bankAccount.size() > 0
          && data.bankAccount.size() <= 60
        ))
        && data.active is bool;
    }

    function hasValidCategoryShape(data) {
      return data.keys().hasOnly(['name', 'normalizedName', 'createdAt'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 50
        && data.normalizedName is string
        && data.normalizedName.size() <= 80
        && data.createdAt is string;
    }

    function hasValidBankAccountShape(data) {
      return data.keys().hasOnly(['name', 'normalizedName', 'createdAt'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 60
        && data.normalizedName is string
        && data.normalizedName.size() <= 80
        && data.createdAt is string;
    }

    function hasValidMonthlyGoalShape(data) {
      return data.keys().hasOnly([
          'monthKey',
          'periodStart',
          'periodEnd',
          'category',
          'accountScope',
          'targetValue',
          'source',
          'rationale',
          'active',
          'createdAt',
          'updatedAt'
        ])
        && data.monthKey is string
        && data.monthKey.size() == 7
        && data.monthKey.matches('^[0-9]{4}-[0-9]{2}$')
        && data.periodStart is string
        && data.periodStart.size() == 10
        && data.periodStart.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.periodEnd is string
        && data.periodEnd.size() == 10
        && data.periodEnd.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 60
        && (!('accountScope' in data) || data.accountScope in ['all', 'Crédito', 'Conta'])
        && data.targetValue is number
        && data.targetValue > 0
        && data.targetValue <= 100000000
        && (!('source' in data) || data.source in ['manual', 'auto'])
        && (!('rationale' in data) || (data.rationale is string && data.rationale.size() <= 400))
        && (!('active' in data) || data.active is bool)
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
    }

    function hasValidUserProfileShape(data) {
      return data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'providerIds',
          'createdAt',
          'lastAccessAt',
          'createdDateKey',
          'lastAccessDateKey',
          'importOperationsTotal',
          'importedTransactionsTotal',
          'manualTransactionsTotal',
          'aiCategorizationRunsTotal',
          'aiConsultantRunsTotal'
        ])
        && (!('uid' in data) || (data.uid is string && data.uid.size() > 0 && data.uid.size() <= 150))
        && (!('email' in data) || (data.email is string && data.email.size() <= 200))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 140))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('providerIds' in data) || (data.providerIds is list && data.providerIds.size() <= 8))
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('lastAccessAt' in data) || (data.lastAccessAt is string && data.lastAccessAt.size() <= 50))
        && (!('createdDateKey' in data) || (data.createdDateKey is string && data.createdDateKey.size() <= 10))
        && (!('lastAccessDateKey' in data) || (data.lastAccessDateKey is string && data.lastAccessDateKey.size() <= 10))
        && (!('importOperationsTotal' in data) || isNonNegativeNumber(data.importOperationsTotal))
        && (!('importedTransactionsTotal' in data) || isNonNegativeNumber(data.importedTransactionsTotal))
        && (!('manualTransactionsTotal' in data) || isNonNegativeNumber(data.manualTransactionsTotal))
        && (!('aiCategorizationRunsTotal' in data) || isNonNegativeNumber(data.aiCategorizationRunsTotal))
        && (!('aiConsultantRunsTotal' in data) || isNonNegativeNumber(data.aiConsultantRunsTotal));
    }

    function hasValidDailyMetricsShape(data) {
      return data.keys().hasOnly([
          'dateKey',
          'aiCategorizationRuns',
          'aiConsultantRuns',
          'importOperations',
          'importedTransactions',
          'manualTransactions',
          'createdAt',
          'updatedAt'
        ])
        && data.dateKey is string
        && data.dateKey.size() == 10
        && isNonNegativeNumber(data.aiCategorizationRuns)
        && isNonNegativeNumber(data.aiConsultantRuns)
        && isNonNegativeNumber(data.importOperations)
        && isNonNegativeNumber(data.importedTransactions)
        && isNonNegativeNumber(data.manualTransactions)
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
    }

    function hasValidOpenFinanceConnectionShape(data) {
      return data.keys().hasOnly([
          'bankCode',
          'bankName',
          'provider',
          'status',
          'consentExpiresAt',
          'lastSyncAt',
          'lastSyncInserted',
          'errorMessage',
          'createdAt',
          'updatedAt'
        ])
        && data.bankCode is string
        && data.bankCode.size() > 0
        && data.bankCode.size() <= 80
        && data.bankName is string
        && data.bankName.size() > 0
        && data.bankName.size() <= 120
        && (!('provider' in data) || (data.provider is string && data.provider.size() > 0 && data.provider.size() <= 80))
        && (!('status' in data) || data.status in ['active', 'expired', 'error', 'revoked', 'unknown'])
        && (!('consentExpiresAt' in data) || (data.consentExpiresAt is string && data.consentExpiresAt.size() <= 50))
        && (!('lastSyncAt' in data) || (data.lastSyncAt is string && data.lastSyncAt.size() <= 50))
        && (!('lastSyncInserted' in data) || isNonNegativeNumber(data.lastSyncInserted))
        && (!('errorMessage' in data) || (data.errorMessage is string && data.errorMessage.size() <= 240))
        && (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 50))
        && (!('updatedAt' in data) || (data.updatedAt is string && data.updatedAt.size() <= 50));
    }

    match /artifacts/{appId}/users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidUserProfileShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidUserProfileShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/transacoes/{transactionId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && hasValidTransactionShape(request.resource.data);

      allow update: if isOwner(userId)
        && hasValidTransactionShape(request.resource.data)
        && request.resource.data.date == resource.data.date
        && request.resource.data.value == resource.data.value
        && request.resource.data.accountType == resource.data.accountType
        && (!('createdBy' in resource.data) || request.resource.data.createdBy == resource.data.createdBy)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);

      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/metrics_daily/{dateKey} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidDailyMetricsShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidDailyMetricsShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/categorias/{categoryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidCategoryShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidCategoryShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/contas_bancarias/{bankAccountId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidBankAccountShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidBankAccountShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/metas_mensais/{goalId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidMonthlyGoalShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidMonthlyGoalShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/open_finance_conexoes/{connectionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasValidOpenFinanceConnectionShape(request.resource.data);
      allow update: if isOwner(userId) && hasValidOpenFinanceConnectionShape(request.resource.data);
      allow delete: if isOwner(userId);
    }

    match /artifacts/{appId}/users/{userId}/consultor_insights/{insightId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
