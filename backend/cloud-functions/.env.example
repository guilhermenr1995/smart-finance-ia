GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash
# Provedor real obrigatório em produção (suportados: pluggy, belvo)
OPEN_FINANCE_PROVIDER=pluggy
OPEN_FINANCE_UPSTREAM_URL=https://your-open-finance-backend.example.com/open-finance
OPEN_FINANCE_UPSTREAM_API_KEY=YOUR_OPEN_FINANCE_UPSTREAM_API_KEY
# true => usa fallback embedded quando upstream estiver placeholder/indisponível
# false => falha com 503/502 quando upstream não estiver operacional
OPEN_FINANCE_ALLOW_FALLBACK=true

# Modo direto da Pluggy (sem upstream intermediário), ideal para fluxo com Meu Pluggy
# auto: ativa quando OPEN_FINANCE_PROVIDER=pluggy e não há upstream real configurado
# on: força modo direto
# off: desativa modo direto
OPEN_FINANCE_PLUGGY_DIRECT_MODE=auto
OPEN_FINANCE_PLUGGY_CLIENT_ID=YOUR_PLUGGY_CLIENT_ID
OPEN_FINANCE_PLUGGY_CLIENT_SECRET=YOUR_PLUGGY_CLIENT_SECRET
# Opcional: se tiver um único item, permite conectar sem informar providerItemId no request
OPEN_FINANCE_PLUGGY_ITEM_IDS=
# Janela de sync de transações (dias para trás)
OPEN_FINANCE_PLUGGY_SYNC_FROM_DAYS=60
