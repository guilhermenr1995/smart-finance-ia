GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# Meu Pluggy (obrigatório para Open Finance)
OPEN_FINANCE_MEU_PLUGGY_CLIENT_ID=YOUR_MEU_PLUGGY_CLIENT_ID
OPEN_FINANCE_MEU_PLUGGY_CLIENT_SECRET=YOUR_MEU_PLUGGY_CLIENT_SECRET
OPEN_FINANCE_MEU_PLUGGY_API_BASE_URL=https://api.pluggy.ai
OPEN_FINANCE_MEU_PLUGGY_SYNC_FROM_DAYS=60
OPEN_FINANCE_MEU_PLUGGY_ACCOUNT_TYPES=BANK,CREDIT

# Webhooks Meu Pluggy
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_ENABLED=true
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_SECRET=YOUR_RANDOM_SECRET
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_HEADER_NAME=x-open-finance-webhook-secret
# Modo de teste: aceita webhook sem header de segredo (permissivo)
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_ALLOW_UNSIGNED=true

# Opcional: autoconfigurar webhooks via API da Pluggy
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_AUTOCONFIG=false
OPEN_FINANCE_MEU_PLUGGY_WEBHOOK_URL=https://YOUR_REGION-YOUR_PROJECT.cloudfunctions.net/openFinanceWebhook
